# ── Begeister Workflow — omgevingsvariabelen ──
# Kopieer dit naar .env (lokaal) en zet dezelfde waarden als "Environment
# Variables" in Vercel. Deel deze waarden NIET in chat of in Git.

# Supabase (Project Settings → API)
SUPABASE_URL=https://xxxxxxxx.supabase.co
SUPABASE_SERVICE_ROLE_KEY=        # server-only! nooit in de browser

# Intake-mailbox bij cloud86 (IMAP)
IMAP_HOST=begeister.nl
IMAP_PORT=993
IMAP_USER=intake@begeister.nl
IMAP_PASSWORD=                    # het wachtwoord dat je in Plesk hebt aangemaakt

# Claude (Anthropic) — voor het structureren van binnenkomende berichten
ANTHROPIC_API_KEY=

# Beveiliging cron-endpoint (zelf een lange willekeurige string verzinnen)
CRON_SECRET=
