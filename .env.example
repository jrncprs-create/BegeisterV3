# ── Begeister — omgevingsvariabelen (.env) ──
# Kopieer dit naar ".env" op de server en vul de waarden in.
# De meeste staan al in Vercel onder: Settings -> Environment Variables.
# Deel deze waarden NIET in chat of in Git.

# Supabase (database + opslag)
SUPABASE_URL=https://xxxxxxxx.supabase.co
SUPABASE_SERVICE_ROLE_KEY=        # server-only! nooit in de browser

# Intake-mailbox (IMAP, bij cloud86)
IMAP_HOST=begeister.nl
IMAP_PORT=993
IMAP_USER=intake@begeister.nl
IMAP_PASSWORD=

# Claude (Anthropic)
ANTHROPIC_API_KEY=

# Dropbox
DROPBOX_APP_KEY=
DROPBOX_APP_SECRET=
# Nieuw adres op de VPS (pas aan als je een ander subdomein kiest):
DROPBOX_REDIRECT_URI=https://app.begeister.nl/api/dropbox/callback

# WhatsApp (Cloud API)
WHATSAPP_VERIFY_TOKEN=begeister-wa-2026
WHATSAPP_TOKEN=                    # vast token, later invullen

# Push-meldingen (web-push / VAPID)
VAPID_PUBLIC_KEY=
VAPID_PRIVATE_KEY=
VAPID_SUBJECT=mailto:jeroen@begeister.nl

# Beveiliging cron-endpoint (lange willekeurige string)
CRON_SECRET=

# Server
PORT=3000
APP_BASE_URL=https://app.begeister.nl
